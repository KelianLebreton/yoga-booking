python -c "
import httpx, json, sys

order_id = 'ord_QS4ko8ZbjRagswQdyw4TJ'
api_key = 'live_tvcjRfztBpx2VrnwKyKu2Da5ApbJJW'

r = httpx.get(
    f'https://api.mollie.com/v2/orders/{order_id}?embed=lines',
    headers={'Authorization': f'Bearer {api_key}'}
)
data = r.json()

print('=== COMMANDE ===')
print('Statut:', data.get('status'))
print('Montant:', data.get('amount', {}).get('value'), data.get('amount', {}).get('currency'))
billing = data.get('billingAddress', {})
print('Email:', billing.get('email'))
print('Nom:', billing.get('givenName'), billing.get('familyName'))
print('Tel:', billing.get('phone'))

print()
print('=== LIGNES DU PANIER ===')
for line in data.get('lines', []) or data.get('_embedded', {}).get('lines', []):
    print('- Nom:', line.get('name'))
    print('  SKU:', line.get('sku'))
    print('  Prix unitaire:', line.get('unitPrice', {}).get('value'))
    print('  Quantité:', line.get('quantity'))
    print()
"