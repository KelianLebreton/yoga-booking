# Copier ce fichier en `.env` et remplir les valeurs. NE JAMAIS committer le vrai `.env`.

# --- Google Sheets / Calendar (même compte de service) ---
SPREADSHEET_ID=            # identifiant du classeur Google Sheets
GOOGLE_CALENDAR_ID=        # ID du calendrier (ex: abc123@group.calendar.google.com)
# Fournir l'UN des deux : chemin vers le fichier JSON, OU le contenu JSON (Render).
GOOGLE_SERVICE_ACCOUNT_JSON=   # chemin local vers le fichier de compte de service
GOOGLE_SERVICE_ACCOUNT_INFO=   # contenu JSON du compte de service (pour Render/Railway)

# --- Mollie (paiements) ---
MOLLIE_API_KEY=           # clé API Mollie (live_... ou test_...)
MOLLIE_WEBHOOK_SECRET=    # optionnel — Webador n'émet pas de webhook, donc inutilisé en pratique

# --- Protection des endpoints /tasks et admin ---
ADMIN_KEY=                # secret aléatoire : python -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Email (API HTTP Brevo — PAS de SMTP, bloqué par Render) ---
BREVO_API_KEY=            # clé API v3 Brevo (Brevo → SMTP & API → API Keys)
EMAIL_FROM=               # adresse expéditrice vérifiée chez Brevo
EMAIL_FROM_NAME=Studio Yoga

# --- Auth élève (JWT signé dans l'URL) ---
JWT_SECRET=               # secret de signature : python -c "import secrets; print(secrets.token_hex(32))"
JWT_EXPIRE_DAYS=365

# --- URL publique de l'app (pour les liens dans les emails) ---
BASE_URL=https://yoga-booking-rocio.onrender.com
